generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================================================================
// 사용자
// ======================================================================
model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String?
  nickname    String
  phoneNumber String?
  provider    String   @default("LOCAL")
  role        String   @default("USER")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile              UserProfile?
  records              Record[]
  challengeParticipants ChallengeParticipant[]
  challengesCreated    Challenge[]            @relation("ChallengeCreator")
  notifications        Notification[]
  activities           UserActivity[]

  @@map("users")
}

// ======================================================================
// 군인 프로필
// ======================================================================
model UserProfile {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  rankName      String?  // 계급 (이병/일병/상병/병장)
  branch        String?  // 군종 (육군/해군/공군/해병)
  unitName      String?  // 소속 부대명
  enlistedAt    String?  // 입대일 "YYYY-MM-DD"
  dischargeDate String?  // 전역 예정일 "YYYY-MM-DD" (보고서 트리거, 필수)
  goal          String?  // 측정가능 목표 (온보딩에서 설정)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ======================================================================
// 기록 (자격증 / 어학 / 독서 / 운동)
// ======================================================================
model Record {
  id          Int      @id @default(autoincrement())
  userId      Int
  category    String   // 자격증 | 어학 | 독서 | 운동
  title       String
  content     String?  // 상세 내용 (정형 필드 JSON 또는 텍스트)
  recordDate  String   // "YYYY-MM-DD"
  verified    Boolean  @default(false)  // 검증 여부 (§9)
  evidenceUrl String?  // 증빙 파일 URL
  meta        String   @default("{}") // 카테고리별 추가 필드 JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, recordDate])
  @@map("records")
}

// ======================================================================
// 챌린지
// ======================================================================
model Challenge {
  id             Int      @id @default(autoincrement())
  creatorId      Int
  title          String
  description    String?
  category       String   // 자격증 | 어학 | 독서 | 운동
  judgmentType   String   @default("NON_COMPETITIVE") // RANKING | PASS_FAIL | NON_COMPETITIVE
  startDate      String   // "YYYY-MM-DD"
  endDate        String   // "YYYY-MM-DD"
  maxParticipants Int?
  isRewarded     Boolean  @default(false) // 보상형 여부 (★ 유료)
  entryFee       Int      @default(0)     // 참가비 (원)
  prizeMoney     Int      @default(0)     // 상금 (원)
  status         String   @default("OPEN") // OPEN | CLOSED | JUDGING | DONE
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  creator      User                   @relation("ChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  participants ChallengeParticipant[]

  @@index([status, startDate])
  @@map("challenges")
}

// ======================================================================
// 챌린지 참여
// ======================================================================
model ChallengeParticipant {
  id          Int      @id @default(autoincrement())
  challengeId Int
  userId      Int
  joinedAt    DateTime @default(now())
  status      String   @default("JOINED") // JOINED | SUBMITTED | JUDGED | REWARDED
  rank        Int?     // 랭킹 트랙
  passed      Boolean? // 합불 트랙
  evidenceUrl String?  // 판정 제출 증빙
  judgedAt    DateTime?

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([challengeId])
  @@index([userId])
  @@map("challenge_participants")
}

// ======================================================================
// 알림
// ======================================================================
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // record / challenge / system
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ======================================================================
// 사용자 활동 (어드민 분석용)
// ======================================================================
model UserActivity {
  id        Int      @id @default(autoincrement())
  userId    Int
  eventType String   // record_created / challenge_joined / challenge_submitted 등
  payload   String   @default("{}")
  platform  String   @default("WEB")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType])
  @@index([eventType, createdAt])
  @@map("user_activities")
}

// ======================================================================
// 어드민
// ======================================================================
model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())

  @@map("admin_users")
}
